# FIP Festival — environment template for Phase 3 (Payload + PostgreSQL)
# Copy this file to .env.local for local development.
# Never commit real secrets. .env and .env*.local are ignored by git.

# PostgreSQL connection used by Payload in Phase 3.
# Use a PostgreSQL connection string in your local/hosting env.
DATABASE_URI=

# Payload signing/encryption secret.
# Generate a long random value for every environment; do not reuse this placeholder.
PAYLOAD_SECRET=

# Public canonical site URL.
# Phase 3 should replace the hardcoded metadataBase in
# src/app/[locale]/layout.tsx with this server-side env var.
SITE_URL=https://www.fipfestival.com.ar

# S3-compatible storage placeholders for Payload media uploads.
# Keep access keys server-side only; never prefix secrets with NEXT_PUBLIC_.
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false
S3_PUBLIC_URL=
