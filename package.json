{
  "name": "fip-festival",
  "version": "0.1.0",
  "private": true,
  "description": "Replica of fipfestival.com.ar — Next.js + Payload (CMS wired in Phase 3)",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed:sponsors": "tsx --require ./scripts/preload-nextenv.cjs scripts/seed-sponsors.ts",
    "seed:edition": "tsx --require ./scripts/preload-nextenv.cjs scripts/seed-edition.ts",
    "seed:rubros": "tsx --require ./scripts/preload-nextenv.cjs scripts/seed-rubros.ts",
    "seed:categories": "tsx --require ./scripts/preload-nextenv.cjs scripts/seed-categories.ts",
    "seed:winners": "tsx --require ./scripts/preload-nextenv.cjs scripts/seed-winners.ts",
    "seed:rankings": "tsx --require ./scripts/preload-nextenv.cjs scripts/seed-rankings.ts",
    "seed:jurors": "tsx --require ./scripts/preload-nextenv.cjs scripts/seed-jurors.ts",
    "seed:hall-of-fame": "tsx --require ./scripts/preload-nextenv.cjs scripts/seed-hall-of-fame.ts",
    "seed:download-files": "tsx --require ./scripts/preload-nextenv.cjs scripts/seed-download-files.ts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.85.0",
    "@payloadcms/next": "^3.85.0",
    "@payloadcms/richtext-lexical": "^3.85.0",
    "country-flag-icons": "^1.6.17",
    "graphql": "^16.14.1",
    "lucide-react": "^0.469.0",
    "next": "^15.1.6",
    "next-intl": "^4.13.0",
    "payload": "^3.85.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.18",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.3",
    "vite-tsconfig-paths": "^5.1.4",
    "tsx": "^4.21.0",
    "vitest": "^2.1.9"
  }
}
